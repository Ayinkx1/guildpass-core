{
  "openapi": "3.0.3",
  "info": {
    "title": "GuildPass Access API",
    "description": "MVP API for wallet membership and access checks",
    "version": "0.1.0"
  },
  "components": {
    "schemas": {
      "WalletAddress": {
        "type": "string",
        "pattern": "^0x[0-9a-fA-F]{40}$",
        "description": "EVM-compatible wallet address (checksummed or lowercase)"
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error", "code", "message", "statusCode"],
        "properties": {
          "error": { "type": "string", "description": "Machine-readable error identifier" },
          "code": { "type": "string", "description": "HTTP status phrase / error code" },
          "message": { "type": "string", "description": "Human-readable description" },
          "statusCode": { "type": "integer", "description": "HTTP status code" },
          "details": {
            "description": "Optional detail payload",
            "oneOf": [{ "type": "string" }, { "type": "object" }]
          }
        }
      },
      "ForbiddenResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": { "type": "string" }
        }
      },
      "RoleMutationResult": {
        "type": "object",
        "required": ["communityId", "wallet", "role", "assigned", "removed"],
        "properties": {
          "communityId": { "type": "string" },
          "wallet": { "$ref": "#/components/schemas/WalletAddress" },
          "role": { "type": "string", "enum": ["admin", "member", "contributor"] },
          "assigned": { "type": "boolean" },
          "removed": { "type": "boolean" },
          "message": { "type": "string" }
        }
      },
      "AccessOverrideMutationResult": {
        "type": "object",
        "required": ["communityId", "wallet", "resource", "effect", "created", "removed"],
        "properties": {
          "communityId": { "type": "string" },
          "wallet": { "$ref": "#/components/schemas/WalletAddress" },
          "resource": { "type": "string" },
          "effect": { "type": "string", "enum": ["ALLOW", "DENY"] },
          "created": { "type": "boolean" },
          "removed": { "type": "boolean" },
          "message": { "type": "string" }
        }
      },
      "BadgeItem": {
        "type": "object",
        "required": ["id", "memberId", "label", "issuedAt"],
        "properties": {
          "id": { "type": "string" },
          "memberId": { "type": "string" },
          "label": { "type": "string" },
          "issuedAt": { "type": "string", "format": "date-time" }
        }
      },
      "BadgeMutationResult": {
        "type": "object",
        "required": ["communityId", "wallet", "assigned", "removed"],
        "properties": {
          "communityId": { "type": "string" },
          "wallet": { "$ref": "#/components/schemas/WalletAddress" },
          "badge": { "$ref": "#/components/schemas/BadgeItem" },
          "assigned": { "type": "boolean" },
          "removed": { "type": "boolean" },
          "message": { "type": "string" }
        }
      },
      "ListBadgesResult": {
        "type": "object",
        "required": ["communityId", "wallet", "badges"],
        "properties": {
          "communityId": { "type": "string" },
          "wallet": { "$ref": "#/components/schemas/WalletAddress" },
          "badges": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BadgeItem" }
          }
        }
      },
      "DeadLetterEvent": {
        "type": "object",
        "required": ["id", "originalEventId", "eventType", "failureReason", "retryCount", "status", "createdAt"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "originalEventId": { "type": "string", "format": "uuid" },
          "eventType": { "type": "string" },
          "entityId": { "type": "string", "nullable": true },
          "entityType": { "type": "string", "nullable": true },
          "communityId": { "type": "string", "nullable": true },
          "payload": { "type": "object", "additionalProperties": true },
          "failureReason": { "type": "string" },
          "retryCount": { "type": "integer", "minimum": 0 },
          "status": { "type": "string", "enum": ["pending", "retried", "resolved"] },
          "createdAt": { "type": "string", "format": "date-time" },
          "resolvedAt": { "type": "string", "format": "date-time", "nullable": true }
        }
      }
    }
  },
  "paths": {
    "/metrics": {
      "get": {
        "summary": "Prometheus metrics scrape endpoint",
        "tags": ["Observability"],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/health/live": {
      "get": {
        "summary": "Liveness probe – is the process alive?",
        "tags": ["Health"],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "version": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health/ready": {
      "get": {
        "summary": "Readiness probe – can we serve traffic?",
        "tags": ["Health"],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "db": { "type": "string" }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "db": { "type": "string" },
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/communities/{communityId}/memberships/{wallet}": {
      "get": {
        "summary": "Get membership status summary for a wallet in a community",
        "tags": ["Memberships"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "communityId",
            "required": true,
            "description": "Community identifier"
          },
          {
            "schema": {
              "type": "string",
              "pattern": "^0x[0-9a-fA-F]{40}$",
              "description": "EVM-compatible wallet address"
            },
            "in": "path",
            "name": "wallet",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Membership summary for the wallet",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "wallet": { "$ref": "#/components/schemas/WalletAddress" },
                    "communities": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["communityId", "state"],
                        "properties": {
                          "communityId": { "type": "string" },
                          "state": { "type": "string", "enum": ["invited", "active", "expired", "suspended"] },
                          "expiresAt": { "type": "string", "format": "date-time", "nullable": true }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Wallet not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/communities/{communityId}/members/{wallet}": {
      "get": {
        "summary": "Get member profile with membership state and roles",
        "tags": ["Members"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "communityId",
            "required": true,
            "description": "Community identifier"
          },
          {
            "schema": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
            "in": "path",
            "name": "wallet",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Member profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "communityId": { "type": "string" },
                    "profile": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string" },
                        "displayName": { "type": "string" },
                        "bio": { "type": "string", "nullable": true },
                        "avatarUrl": { "type": "string", "nullable": true }
                      }
                    },
                    "membership": {
                      "type": "object",
                      "properties": {
                        "state": { "type": "string", "enum": ["invited", "active", "expired", "suspended"] },
                        "expiresAt": { "type": "string", "format": "date-time", "nullable": true }
                      }
                    },
                    "roles": {
                      "type": "array",
                      "items": { "type": "string", "enum": ["admin", "member", "contributor"] }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Member not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/communities/{communityId}/members/{wallet}/roles": {
      "post": {
        "summary": "Assign a role to a community member",
        "tags": ["Members", "Roles"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "communityId",
            "required": true,
            "description": "Community identifier"
          },
          {
            "schema": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
            "in": "path",
            "name": "wallet",
            "required": true
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["role"],
                "properties": {
                  "role": { "type": "string", "enum": ["admin", "member", "contributor"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Role assigned successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RoleMutationResult" }
              }
            }
          },
          "400": {
            "description": "Validation error (invalid wallet, unknown community, or unrecognized role)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Forbidden — requester does not have permission",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/communities/{communityId}/members/{wallet}/roles/{role}": {
      "delete": {
        "summary": "Remove a role from a community member",
        "tags": ["Members", "Roles"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "communityId",
            "required": true,
            "description": "Community identifier"
          },
          {
            "schema": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
            "in": "path",
            "name": "wallet",
            "required": true
          },
          {
            "schema": { "type": "string", "enum": ["admin", "member", "contributor"] },
            "in": "path",
            "name": "role",
            "required": true,
            "description": "Role to remove"
          }
        ],
        "responses": {
          "200": {
            "description": "Role removed successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RoleMutationResult" }
              }
            }
          },
          "400": {
            "description": "Validation error (invalid wallet, unknown community, or unrecognized role)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Forbidden — requester does not have permission",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/communities/{communityId}/members/{wallet}/badges": {
      "post": {
        "summary": "Assign a badge to a community member",
        "tags": ["Members", "Badges"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "communityId",
            "required": true,
            "description": "Community identifier"
          },
          {
            "schema": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
            "in": "path",
            "name": "wallet",
            "required": true
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["label"],
                "properties": {
                  "label": { "type": "string", "minLength": 1, "description": "Badge label to assign" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Badge assigned successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BadgeMutationResult" }
              }
            }
          },
          "400": {
            "description": "Validation error (invalid wallet, unknown community, or missing label)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Forbidden — requester does not have permission",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          },
          "404": {
            "description": "Target wallet is not a member of the community",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List badges assigned to a community member",
        "tags": ["Members", "Badges"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "communityId",
            "required": true,
            "description": "Community identifier"
          },
          {
            "schema": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
            "in": "path",
            "name": "wallet",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Badges for the member",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListBadgesResult" }
              }
            }
          },
          "400": {
            "description": "Validation error (invalid wallet or unknown community)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Target wallet is not a member of the community",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/communities/{communityId}/members/{wallet}/badges/{badgeId}": {
      "delete": {
        "summary": "Revoke a badge from a community member",
        "tags": ["Members", "Badges"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "communityId",
            "required": true,
            "description": "Community identifier"
          },
          {
            "schema": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
            "in": "path",
            "name": "wallet",
            "required": true
          },
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "badgeId",
            "required": true,
            "description": "Badge identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Badge revoked (or was already absent)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BadgeMutationResult" }
              }
            }
          },
          "400": {
            "description": "Validation error (invalid wallet or unknown community)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Forbidden — requester does not have permission",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          },
          "404": {
            "description": "Target wallet is not a member of the community",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/communities/{communityId}/overrides": {
      "post": {
        "summary": "Create or update an access override for a wallet/resource pair",
        "tags": ["Overrides"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "communityId",
            "required": true,
            "description": "Community identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["wallet", "resource", "effect"],
                "properties": {
                  "wallet": { "$ref": "#/components/schemas/WalletAddress" },
                  "resource": { "type": "string", "description": "Resource identifier" },
                  "effect": { "type": "string", "enum": ["ALLOW", "DENY"] },
                  "reason": { "type": "string", "nullable": true },
                  "expiresAt": { "type": "string", "format": "date-time", "nullable": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Override created or updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AccessOverrideMutationResult" }
              }
            }
          },
          "400": {
            "description": "Validation error — missing required fields",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Forbidden — requester does not have permission",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/communities/{communityId}/overrides/{wallet}/{resource}": {
      "delete": {
        "summary": "Revoke an access override for a wallet/resource pair",
        "tags": ["Overrides"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "communityId",
            "required": true,
            "description": "Community identifier"
          },
          {
            "schema": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
            "in": "path",
            "name": "wallet",
            "required": true
          },
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "resource",
            "required": true,
            "description": "Resource identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Override revoked",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AccessOverrideMutationResult" }
              }
            }
          },
          "403": {
            "description": "Forbidden — requester does not have permission",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/access/check": {
      "post": {
        "summary": "Check whether a wallet has access to a resource in a community",
        "tags": ["Access"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["wallet", "communityId", "resource"],
                "properties": {
                  "wallet": { "$ref": "#/components/schemas/WalletAddress" },
                  "communityId": { "type": "string", "description": "Community identifier" },
                  "resource": { "type": "string", "description": "Resource identifier" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access decision",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["allowed", "code"],
                  "properties": {
                    "allowed": { "type": "boolean", "description": "Whether access is granted" },
                    "code": { "type": "string", "enum": ["ALLOW", "DENY"] },
                    "reasons": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["code", "message"],
                        "properties": {
                          "code": { "type": "string" },
                          "message": { "type": "string" }
                        }
                      }
                    },
                    "effectiveRoles": {
                      "type": "array",
                      "items": { "type": "string", "enum": ["admin", "member", "contributor"] },
                      "nullable": true
                    },
                    "membershipState": {
                      "type": "string",
                      "enum": ["invited", "active", "expired", "suspended"],
                      "nullable": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error — missing required fields",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/communities/{communityId}/members": {
      "get": {
        "summary": "List community members (admin)",
        "tags": ["Members"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "communityId",
            "required": true,
            "description": "Community identifier"
          },
          {
            "schema": { "type": "string", "enum": ["admin", "member", "contributor"] },
            "in": "query",
            "name": "role",
            "required": false,
            "description": "Filter members by role"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated member list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["members"],
                  "properties": {
                    "members": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "wallet": { "$ref": "#/components/schemas/WalletAddress" },
                          "displayName": { "type": "string", "nullable": true },
                          "state": { "type": "string", "enum": ["invited", "active", "expired", "suspended"] },
                          "roles": {
                            "type": "array",
                            "items": { "type": "string", "enum": ["admin", "member", "contributor"] }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden — requester is not a community admin",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/communities/{communityId}/dead-letter-events": {
      "get": {
        "summary": "List dead-lettered webhook delivery events for a community",
        "tags": ["Dead Letter"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "communityId",
            "required": true,
            "description": "Community identifier"
          },
          {
            "schema": { "type": "string", "enum": ["pending", "retried", "resolved"] },
            "in": "query",
            "name": "status",
            "required": false,
            "description": "Filter events by status"
          }
        ],
        "responses": {
          "200": {
            "description": "List of dead-letter events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["events"],
                  "properties": {
                    "events": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/DeadLetterEvent" }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden — requester is not a community admin",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          }
        }
      }
    },
    "/v1/communities/{communityId}/dead-letter-events/{id}/retry": {
      "post": {
        "summary": "Re-enqueue a dead-lettered event for redelivery",
        "tags": ["Dead Letter"],
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "communityId",
            "required": true,
            "description": "Community identifier"
          },
          {
            "schema": { "type": "string", "format": "uuid" },
            "in": "path",
            "name": "id",
            "required": true,
            "description": "Dead-letter event ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Event re-enqueued successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["newEventId"],
                  "properties": {
                    "newEventId": {
                      "type": "string",
                      "format": "uuid",
                      "description": "ID of the newly created pending outbox event"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden — requester is not a community admin",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          },
          "404": {
            "description": "Dead-letter event not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "409": {
            "description": "Event has already been retried or resolved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ForbiddenResponse" }
              }
            }
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ]
}
