datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Community {
  id          String            @id
  name        String
  members     Member[]
  policies    AccessPolicy[]
  resources   Resource[]
  overrides   AccessOverride[]
  rules       GovernanceRule[]
  createdAt   DateTime          @default(now())
}

model Wallet {
  id                    String          @id @default(cuid())
  address               String          @unique
  members               Member[]
  createdAt             DateTime        @default(now())
  // Wallet linking: this wallet is primary
  primaryLinkedWallets  LinkedWallet[]  @relation("primaryWallet")
  // Wallet linking: this wallet is linked to a primary
  secondaryLinkedWallets LinkedWallet[] @relation("secondaryWallet")
  challenges            Challenge[] @relation("challengePrimaryWallet")
  secondaryChallenges   Challenge[] @relation("challengeSecondaryWallet")
}

// --- Wallet Linking Models ---

// Challenges for wallet linking (prevents replay attacks)
model Challenge {
  id                String   @id @default(uuid())
  nonce             String   @unique
  primaryWalletId   String
  secondaryWalletId String
  primaryWallet     Wallet   @relation("challengePrimaryWallet", fields: [primaryWalletId], references: [id])
  secondaryWallet   Wallet   @relation("challengeSecondaryWallet", fields: [secondaryWalletId], references: [id])
  issuedAt          DateTime @default(now())
  expiresAt         DateTime
  used              Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([primaryWalletId])
  @@index([secondaryWalletId])
  @@index([nonce])
}

// Links a secondary wallet to a primary identity
model LinkedWallet {
  id                 String   @id @default(uuid())
  primaryWalletId    String
  secondaryWalletId  String   @unique
  primaryWallet      Wallet   @relation("primaryWallet", fields: [primaryWalletId], references: [id])
  secondaryWallet    Wallet   @relation("secondaryWallet", fields: [secondaryWalletId], references: [id])
  // Denormalize addresses for easier querying
  primaryWalletAddress  String
  secondaryWalletAddress String
  linkedAt           DateTime @default(now())

  @@index([primaryWalletId])
  @@unique([primaryWalletId, secondaryWalletId])
}

model Profile {
  id          String   @id @default(cuid())
  displayName String
  bio         String?
  members     Member[]
}

model Member {
  id          String           @id @default(cuid())
  communityId String
  walletId    String
  profileId   String?
  community   Community        @relation(fields: [communityId], references: [id])
  wallet      Wallet           @relation(fields: [walletId], references: [id])
  profile     Profile?         @relation(fields: [profileId], references: [id])
  membership  Membership?
  roles       RoleAssignment[]
  badges      Badge[]
  appeals     Appeal[]

  @@unique([communityId, walletId])
}

enum MembershipState {
  invited
  active
  expired
  suspended
}

model Membership {
  id        String          @id @default(cuid())
  memberId  String          @unique
  tokenId   Int?            @unique
  state     MembershipState
  expiresAt DateTime?
  renewedAt DateTime?
  createdAt DateTime        @default(now())
  member    Member          @relation(fields: [memberId], references: [id])

  @@index([state, expiresAt])
  @@index([tokenId])
}

enum Role {
  admin
  member
  contributor
}

enum RoleSource {
  manual
  auto
}

model RoleAssignment {
  id        String     @id @default(cuid())
  memberId  String
  role      Role
  source    RoleSource
  active    Boolean    @default(true)
  expiresAt DateTime?
  createdAt DateTime   @default(now())
  member    Member     @relation(fields: [memberId], references: [id])
}

model Badge {
  id       String   @id @default(cuid())
  memberId String
  label    String
  issuedAt DateTime @default(now())
  member   Member   @relation(fields: [memberId], references: [id])

  @@index([memberId])
}

model Resource {
  id          String   @id @default(cuid())
  communityId String
  resourceId  String
  name        String
  metadata    Json?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  community Community @relation(fields: [communityId], references: [id])

  @@unique([communityId, resourceId])
  @@index([communityId])
  @@index([archived])
}

model AccessPolicy {
  id          String    @id @default(cuid())
  communityId String
  resource    String
  ruleType    String
  params      Json?
  community   Community @relation(fields: [communityId], references: [id])

  @@unique([communityId, resource])
}

enum AccessOverrideEffect {
  ALLOW
  DENY
}

model AccessOverride {
  id          String                @id @default(cuid())
  wallet      String
  communityId String
  resource    String
  effect      AccessOverrideEffect
  reason      String?
  expiresAt   DateTime?
  createdAt   DateTime              @default(now())
  community   Community             @relation(fields: [communityId], references: [id])

  @@unique([communityId, wallet, resource])
  @@index([communityId])
  @@index([wallet])
  @@index([resource])
}

generator client {
  provider = "prisma-client-js"
}

// --- existing models above (User, Wallet, Community, Member, Policy, etc.) ---

enum EventType {
  ACCESS_CHECK
  MEMBERSHIP_CREATED
  MEMBERSHIP_UPDATED
  MEMBERSHIP_DELETED
  POLICY_EVALUATION
  MEMBERSHIP_RECONCILED
  OTHER
}

model AuditEvent {
  id          String    @id @default(uuid())
  eventType   EventType
  walletId    String? // optional: some events may not have a wallet
  communityId String? // optional
  resource    String?
  policyRule  String?
  decision    String? // e.g. "ALLOW", "DENY"
  reasonCode  String? // machine-readable code for decision
  beforeState Json?
  afterState  Json?
  
  // Correlation ID for linking related events across the system
  correlationId String?
  
  // On-chain event metadata (when audit event originated from blockchain)
  chainId         Int?
  txHash          String?
  blockNumber     Int?
  logIndex        Int?
  
  // Snapshot of state versions at time of access decision
  membershipStateVersion String? // JSON snapshot of membership state used
  roleStateVersion       String? // JSON snapshot of roles used
  
  // Hash-chain integrity fields
  // recordHash = keccak256(canonicalize(record fields) + previousRecordHash)
  // Forms a tamper-evident chain that allows detection of retroactive alteration or deletion.
  recordHash         String? @unique
  previousRecordHash String?
  
  createdAt   DateTime  @default(now())

  @@index([walletId])
  @@index([communityId])
  @@index([createdAt])
  @@index([correlationId])
  @@index([txHash])
  @@index([previousRecordHash])
  @@index([communityId, createdAt])
  @@index([communityId, walletId])
  @@index([communityId, eventType])
  @@index([communityId, resource])
}

// --- Integration Event Outbox ---

enum OutboxEventStatus {
  pending
  delivered
  failed
}

model OutboxEvent {
  id            String            @id @default(uuid())
  eventType     String // e.g. "MEMBERSHIP_CREATED", "ROLE_ASSIGNED", "RESOURCE_CREATED"
  entityId      String? // ID of the entity that changed (memberId, resourceId, etc.)
  entityType    String? // e.g. "Member", "RoleAssignment", "Resource", "AccessPolicy"
  communityId   String? // community context
  // Groups outbox events emitted by the same originating request/mutation so
  // consumers can correlate related events (e.g. a role change plus its
  // downstream access re-evaluation). Nullable additive column — see the
  // "Simple case" worked example in CONTRIBUTING.md's migration guide.
  correlationId String?

  // On-chain event metadata (when outbox event originated from blockchain)
  chainId       Int?
  txHash        String?
  blockNumber   Int?
  logIndex      Int?

  payload       Json              @default("{}")
  status        OutboxEventStatus @default(pending)
  retryCount    Int               @default(0)
  maxRetries    Int               @default(5)
  lastError     String?
  createdAt     DateTime          @default(now())
  deliveredAt   DateTime?
  nextRetryAt   DateTime?

  // Distributed claim lease for multi-instance outbox workers (issue #94).
  // A worker claims a batch via `SELECT ... FOR UPDATE SKIP LOCKED` and
  // stamps these three columns in the same statement. The row remains
  // claimable by no one else until claimExpiresAt passes, at which point
  // any worker (including a live one polling again) may reclaim it —
  // this is how a crashed worker's in-flight rows self-heal without a
  // separate reaper process. See services/outboxService.ts#claimPendingOutboxEvents.
  claimedAt      DateTime?
  claimedBy      String?
  claimExpiresAt DateTime?

  @@index([status])
  @@index([communityId])
  @@index([eventType])
  @@index([createdAt])
  @@index([nextRetryAt])
  // No (status, nextRetryAt, claimExpiresAt) composite index was added for
  // the claim query, and this existing (status, nextRetryAt) index is not
  // what serves it either — verified with EXPLAIN ANALYZE against 100k
  // seeded rows (90% pending/leased, matching a high-contention shape) in a
  // worst-case sort distribution (matching rows at the far end of createdAt
  // order): the planner resolves the query via the @@index([createdAt])
  // above (walking it in ORDER BY order, filtering, stopping at LIMIT), and
  // falls back to a sequential scan if that index is unavailable. A
  // composite (status, nextRetryAt, claimExpiresAt) index was tried and
  // never chosen by the planner in either case — status alone has poor
  // selectivity here (most pending rows are also past nextRetryAt), so an
  // index scan on it costs about the same as a sequential scan — and
  // dropping the (status, nextRetryAt) index changed neither plan nor cost.
  // An unused index is a permanent write-path cost with no read-side
  // benefit here, so neither was added.
  @@index([status, nextRetryAt])
  @@index([correlationId])
}

// --- Chain Indexer Reorg Safety & Idempotency ---

model ProcessedEvent {
  id              String   @id @default(uuid())
  transactionHash String
  logIndex        Int
  blockHash       String
  blockNumber     Int
  eventType       String
  processedAt     DateTime @default(now())

  @@unique([transactionHash, logIndex])
  @@index([blockHash])
  @@index([blockNumber])
}

model IndexerState {
  id               String   @id @default("singleton")
  lastBlockNumber  Int
  lastBlockHash    String
  updatedAt        DateTime @updatedAt
}

model GovernanceRule {
  id          String   @id @default(uuid())
  name        String
  description String
  communityId String
  resource    String
  ast         Json
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  community Community @relation(fields: [communityId], references: [id])

  @@unique([communityId, resource, name])
  @@index([communityId])
  @@index([resource])
  @@index([active])
}

enum ApprovalRequestStatus {
  pending
  approved
  rejected
  expired
}

model ApprovalRequest {
  id              String                @id @default(uuid())
  communityId     String
  resource        String
  requesterWallet String
  ruleId          String
  status          ApprovalRequestStatus @default(pending)
  expiresAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  approvals       Approval[]

  @@index([communityId])
  @@index([requesterWallet])
  @@index([ruleId])
  @@index([status])
  @@index([createdAt])
}

model Approval {
  id             String          @id @default(uuid())
  requestId      String
  approverWallet String
  approverRole   String
  approved       Boolean
  timestamp      DateTime        @default(now())
  signature      String?
  request        ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, approverWallet])
  @@index([requestId])
  @@index([approverWallet])
}

model ContributionScore {
  id         String   @id @default(uuid())
  walletId   String
  communityId String
  totalScore Int      @default(0)
  breakdown  Json?
  updatedAt  DateTime @updatedAt

  @@unique([walletId, communityId])
  @@index([communityId])
  @@index([totalScore])
}

// --- Webhook Delivery (outbox handler) ---

// A community's subscription to outbox events, delivered as signed HTTP
// webhooks by createWebhookHandler (src/handlers/webhookHandler.ts).
model WebhookSubscription {
  id          String   @id @default(cuid())
  communityId String
  url         String
  // Shared secret used to HMAC-SHA256 sign delivered payloads. Treat as a
  // credential: never log it, and prefer a secrets manager over plaintext
  // storage in production deployments.
  secret      String
  // Event types this subscription receives, e.g. "MEMBERSHIP_CREATED".
  // Empty array means "all event types" for this community.
  eventTypes  String[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([communityId])
  @@index([active])
}

enum DeadLetterStatus {
  pending
  retried
  resolved
}

// Outbox events that exhausted the outbox's own retry/backoff budget
// (OutboxEvent.status = "failed") land here instead of being silently
// pruned, so they remain inspectable and manually retriable via the admin
// dead-letter routes.
model DeadLetterEvent {
  id              String           @id @default(uuid())
  originalEventId String
  eventType       String
  entityId        String?
  entityType      String?
  communityId     String?
  payload         Json             @default("{}")
  failureReason   String
  retryCount      Int
  status          DeadLetterStatus @default(pending)
  createdAt       DateTime         @default(now())
  resolvedAt      DateTime?

  @@index([status])
  @@index([communityId])
  @@index([createdAt])
  @@index([originalEventId])
}

model SiweNonce {
  id        String   @id @default(uuid())
  nonce     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Session {
  id            String   @id @default(uuid())
  walletAddress String
  token         String   @unique
  expiresAt     DateTime
  createdAt     DateTime @default(now())
}

enum AppealStatus {
  filed
  under_review
  upheld
  reinstated
}

model Appeal {
  id           String       @id @default(uuid())
  memberId     String
  reason       String
  status       AppealStatus @default(filed)
  adminComment String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  member       Member       @relation(fields: [memberId], references: [id])
}

model IndexerCheckpoint {
  chainId             Int      @id
  lastProcessedBlock  Int
  lastProcessedBlockHash String
  updatedAt           DateTime @updatedAt
}

model BlockHeader {
  chainId             Int
  blockNumber         Int
  blockHash           String

  @@id([chainId, blockNumber])
  @@index([blockNumber])
}

model StreakState {
  id             String   @id @default(uuid())
  walletId       String
  communityId    String
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastActivityAt DateTime
  graceUsed      Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  @@unique([walletId, communityId])
}

enum RewardActionType {
  GRANT_BADGE
  UPGRADE_ROLE
}

model RewardRule {
  id           String           @id @default(uuid())
  communityId  String
  milestone    Int              // streak count threshold
  actionType   RewardActionType
  actionParams Json             // e.g. { badgeLabel: "7-Day Streak" } or { role: "contributor" }
  createdAt    DateTime         @default(now())

  @@unique([communityId, milestone, actionType])
}

model StreakRewardHistory {
  id          String   @id @default(uuid())
  walletId    String
  communityId String
  ruleId      String
  awardedAt   DateTime @default(now())

  @@unique([walletId, communityId, ruleId])
}

model AttendanceRecord {
  id          String   @id @default(uuid())
  walletId    String
  communityId String
  eventId     String
  source      String   // e.g. "manual", "webhook", "on-chain"
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([walletId, eventId, source])
  @@index([communityId])
}





